# === OpenAI API ===
OPENAI_API_KEY=sk-your-openai-api-key-here

# === Facebook Integration ===
FB_PAGE_ID=your-facebook-page-id
FB_PAGE_ACCESS_TOKEN=your-facebook-page-access-token

# === LinkedIn Integration ===
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
# Use EITHER person URN (for personal posts) OR org URN (for organization posts)
LINKEDIN_PERSON_URN=urn:li:person:XXXXXXXXX
LINKEDIN_ORG_URN=urn:li:organization:XXXXXXXXX

# === Database & Storage ===
DB_PATH=posts.db
MEDIA_DIR=media

# === Scheduling ===
TZ=Europe/Bucharest
POST_HOUR=09:00

# === Cost Tracking (optional thresholds) ===
DAILY_COST_LIMIT_USD=5.0
MONTHLY_COST_LIMIT_USD=100.0

# === Brand Voice (comma-separated bullets) ===
BRAND_BULLETS=Romania context,tech + educational + funny,no fluff clear CTA,professional yet approachable
