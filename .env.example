# === OpenAI Configuration ===
OPENAI_API_KEY=sk-...

# === Facebook Page Configuration ===
FB_PAGE_ID=your_page_id
FB_PAGE_ACCESS_TOKEN=your_page_access_token

# === LinkedIn Configuration ===
# Use either PERSON_URN (personal profile) or ORG_URN (company page)
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_PERSON_URN=urn:li:person:XXXXX
LINKEDIN_ORG_URN=urn:li:organization:XXXXX

# === Database & Storage ===
DB_PATH=posts.db
MEDIA_DIR=media

# === Scheduling Configuration ===
TZ=Europe/Bucharest
POST_HOUR=09:00

# === Brand Configuration ===
BRAND_NAME=Your Brand
BRAND_CONTEXT=Romania context, tech-focused
BRAND_STYLE=educational + funny, no fluff, clear CTA

# === Trend Discovery Sources (comma-separated RSS feeds) ===
TREND_SOURCES=https://news.ycombinator.com/rss,https://rss.nytimes.com/services/xml/rss/nyt/Technology.xml
